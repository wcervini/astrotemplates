{
  "name": "popular-point",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "check:watch": "astro check --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"src/**/*.{astro,js,jsx,ts,tsx,json,css,scss}\"",
    "format:fix": "prettier --write \"src/**/*.{astro,js,jsx,ts,tsx,json,css,scss}\" \"*.{mjs,json}\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/tailwind": "^6.0.0",
    "astro": "^6.4.7",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-sort-imports": "1.8.11",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript-eslint": "^8.24.0"
  }
}
