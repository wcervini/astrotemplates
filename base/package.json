{
  "name": "Mi Astro Template Base",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "check:watch": "astro check --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"src/**/*.{astro,js,jsx,ts,tsx,json,css,scss}\"",
    "format:fix": "prettier --write \"src/**/*.{astro,js,jsx,ts,tsx,json,css,scss}\" \"*.{mjs,json}\""
  },
  "dependencies": {
    "astro": "^6.4.7",
    "daisyui":"latest",
    "@tailwindcss/vite":"4.3.1",
    "astro-icon":"1.1.5"

  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-sort-imports": "1.8.11",
    "prettier-plugin-sort-json": "4.2.0",
    "prettier-plugin-tailwindcss": "0.6.11",
    "typescript-eslint": "^8.24.0",
    "@iconify/json":"2.2.486",
    "tailwindcss":"4.3.1",
    "@fontsource-variable/roboto":"5.2.10"
  }
}
